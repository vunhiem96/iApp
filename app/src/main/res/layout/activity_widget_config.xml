<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="16dp">

        <!-- PREVIEW -->
        <LinearLayout
            android:id="@+id/previewContainer"
            android:layout_width="match_parent"
            android:layout_height="125dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/background_search_light"
            android:backgroundTint="#9E9E9E"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/previewIcon"
                android:layout_width="64dp"
                android:layout_height="64dp" />

            <TextView
                android:id="@+id/previewName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- NAME -->

        <EditText
            android:id="@+id/editName"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_35sdp"
            android:layout_marginTop="@dimen/_5sdp"
            android:fontFamily="@font/font"
            android:gravity="center_vertical"
            android:hint="@string/edit_app_name"
            android:inputType="textNoSuggestions"
            android:textColor="#000000"
            android:textColorHint="#969799"
            android:textSize="@dimen/_13ssp" />


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_10sdp"
            android:orientation="horizontal">

            <com.suke.widget.SwitchButton
                android:id="@+id/switchShowName"
                android:layout_width="@dimen/_42sdp"
                android:layout_height="@dimen/_26sdp"
                android:layout_marginEnd="@dimen/_15sdp"
                app:sb_background="#e9e9eb"
                app:sb_checked="true"
                app:sb_checked_color="#67cd67"
                app:sb_show_indicator="false"
                app:sb_uncheck_color="#e9e9eb" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:fontFamily="@font/font"
                android:text="@string/show_app_name"
                android:textColor="@color/black"
                android:textSize="@dimen/_12ssp" />

        </LinearLayout>


        <!-- COLOR PICKER SIMPLE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <View
                android:id="@+id/colorBlack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/background_radius_5_border_black" />

            <View
                android:id="@+id/colorWhite"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginHorizontal="1dp"
                android:background="@drawable/background_radius_5_border" />

            <View
                android:id="@+id/colorRed"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/background_radius_5_border_red" />

            <View
                android:id="@+id/colorBlue"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginHorizontal="1dp"
                android:background="@drawable/background_radius_5_border_xanh" />

            <View
                android:id="@+id/colorGreen"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/background_radius_5_border_xanh_la" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="@dimen/_15sdp"
                android:fontFamily="@font/font"
                android:text="@string/app_name_text_color"
                android:textColor="@color/black"
                android:textSize="@dimen/_12ssp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnPickImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />
        <!-- SAVE -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_10sdp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:fontFamily="@font/font"
                    android:text="@string/select_app"
                    android:textColor="@color/black"
                    android:textSize="@dimen/_16ssp"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="@dimen/_10sdp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:overScrollMode="never" />

                    <FrameLayout
                        android:id="@+id/loadingView"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_200sdp">

                        <ProgressBar
                            android:layout_width="@dimen/_38sdp"
                            android:layout_height="@dimen/_38sdp"
                            android:layout_gravity="center"
                            android:indeterminateTint="@color/nuoc_bien" />
                    </FrameLayout>

                </FrameLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_85sdp" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>


    </LinearLayout>

    <TextView
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_40sdp"
        android:layout_alignParentBottom="true"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="@dimen/_25sdp"
        android:background="@drawable/background_edt_dialog"
        android:backgroundTint="@color/main_color"
        android:fontFamily="@font/font"
        android:gravity="center"
        android:text="@string/save_widget"
        android:textAllCaps="true"
        android:textColor="@color/white"
        android:textSize="@dimen/_14ssp"
        android:textStyle="bold" />
</RelativeLayout>